	"screenshots": [{
		"src": "docs/screenshots/joplin-kan-1.png",
		"label": "Simple kanban panel with drag-n-drop task"
	}],
	"icons": {
		"16": "assets/joplin-kan-16.png",
		"32": "assets/joplin-kan-32.png",
		"48": "assets/joplin-kan-48.png",
		"128": "assets/joplin-kan-128.png"
	}
