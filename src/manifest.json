{
	"manifest_version": 1,
	"id": "com.github.txnam.joplinkan",
	"app_min_version": "3.5",
	"version": "0.5.0",
	"name": "JoplinKan",
	"description": "Create and edit Kanban boards directly in Joplin Markdown notes.",
	"author": "https://github.com/txnam/JoplinKan",
	"homepage_url": "https://github.com/txnam/JoplinKan",
	"repository_url": "https://github.com/txnam/JoplinKan",
	"app_min_version_mobile": "3.0.1",
	"platforms": ["desktop", "mobile"],
